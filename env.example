# ── Required ──────────────────────────────────────────────────────────────────
# Gemini AI API key (get from Google AI Studio: https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Whapi.Cloud API token (get from https://whapi.cloud — free tier available)
# This is used to send messages to WhatsApp groups
WHAPI_TOKEN=your_whapi_token_here

# App admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Secret to protect the cron endpoint (recommended in production)
CRON_SECRET=any_random_secret_string

# Node environment
NODE_ENV=development
